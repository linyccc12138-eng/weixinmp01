.play-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #1A1A1A;
}

.video-container {
  position: relative;
  width: 100%;
  background: #000;
  flex-shrink: 0;
}

.video-player {
  width: 100%;
  height: 225px;
}

.watermark-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.watermark-text {
  font-size: 14px;
  color: rgba(255,255,255,0.08);
  transform: rotate(-30deg);
  white-space: nowrap;
  letter-spacing: 4px;
}

.play-content {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16px 16px 0 0;
  margin-top: -8px;
}

.chapter-info-section {
  padding: 20px 24px 16px;
}

.chapter-title {
  font-size: 18px;
  font-weight: 500;
  color: #1A1A1A;
}

.chapter-course {
  font-size: 12px;
  color: #888;
  margin-top: 4px;
}

.chapters-panel {
  border-top: 1px solid #F0F0F0;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 24px;
}

.panel-title {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A1A;
}

.panel-toggle {
  font-size: 12px;
  color: #888;
}

.chapter-list {
  padding: 0 24px 12px;
  max-height: 300px;
  overflow-y: auto;
}

.chapter-item {
  display: flex;
  align-items: center;
  padding: 10px 0;
  gap: 10px;
  border-bottom: 1px solid #F7F7F7;
}

.chapter-item.active {
  background: #F7F7F7;
  border-left: 3px solid #1A1A1A;
  padding-left: 8px;
}

.chapter-item.completed .chapter-name {
  color: #888;
}

.chapter-index {
  font-size: 12px;
  color: #BBB;
  width: 20px;
  text-align: center;
}

.chapter-name {
  flex: 1;
  font-size: 14px;
  color: #1A1A1A;
}

.chapter-status-icon {
  font-size: 12px;
  color: #22C55E;
}

.speed-section {
  padding: 14px 24px;
  border-top: 1px solid #F0F0F0;
}

.speed-label {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 10px;
}

.speed-list {
  white-space: nowrap;
}

.speed-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 32px;
  padding: 0 14px;
  margin-right: 8px;
  border-radius: 100px;
  background: #F7F7F7;
  font-size: 13px;
  color: #888;
}

.speed-item.active {
  background: #1A1A1A;
  color: #FFFFFF;
}
