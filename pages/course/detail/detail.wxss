.page {
  padding-bottom: calc(32px + env(safe-area-inset-bottom));
}

.course-header {
  position: relative;
  height: 200px;
  overflow: hidden;
}

.course-cover {
  width: 100%;
  height: 100%;
}

.course-cover-placeholder {
  background: linear-gradient(135deg, #1A1A1A, #3D3D3D);
}

.header-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24px;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
  color: #FFFFFF;
}

.course-title {
  font-size: 22px;
  font-weight: 500;
  line-height: 1.3;
}

.course-desc {
  font-size: 13px;
  opacity: 0.9;
  margin-top: 8px;
  line-height: 1.5;
}

.course-meta {
  display: flex;
  gap: 16px;
  margin-top: 8px;
}

.meta-item {
  font-size: 12px;
  opacity: 0.9;
}

.progress-section {
  padding: 16px 24px;
  background: #FFFFFF;
  border-bottom: 1px solid #F0F0F0;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
}

.progress-label {
  font-size: 14px;
  color: #1A1A1A;
}

.progress-value {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A1A;
}

.continue-btn {
  margin-top: 12px;
  padding: 12px 20px;
  background: #1A1A1A;
  color: #FFFFFF;
  border-radius: 100px;
  font-size: 14px;
  font-weight: 500;
  text-align: center;
}

.continue-btn:active {
  opacity: 0.85;
}

.lock-notice {
  padding: 16px 24px;
  background: #FFF8E1;
}

.lock-text {
  font-size: 13px;
  color: #856404;
}

.chapters-section {
  padding: 16px 24px;
}

.section-title {
  font-size: 18px;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 12px;
}

.chapter-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  background: #F0F0F0;
  border-radius: 12px;
  overflow: hidden;
}

.chapter-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: #FFFFFF;
  gap: 12px;
  transition: background 150ms ease;
}

.chapter-item:active {
  background: #F7F7F7;
}

.chapter-item.locked {
  opacity: 0.6;
}

.chapter-item.completed .chapter-title {
  color: #888;
}

.chapter-index {
  width: 26px;
  height: 26px;
  border-radius: 100px;
  background: rgba(26, 26, 26, 0.58);
  color: #FFFFFF;
  font-size: 12px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.chapter-info {
  flex: 1;
  min-width: 0;
}

.chapter-title {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A1A;
}

.chapter-meta {
  display: flex;
  gap: 8px;
  margin-top: 4px;
}

.meta-text {
  font-size: 11px;
  color: #888;
}

.completed-text {
  color: #22C55E;
}

.chapter-status {
  flex-shrink: 0;
}

.status-icon {
  width: 28px;
  height: 28px;
  border-radius: 100px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

.completed-icon {
  background: #E8F5E9;
  color: #22C55E;
}

.play-icon {
  background: #F5F5F5;
  color: #1A1A1A;
}

.lock-icon {
  background: #FFF0F0;
  color: #BBB;
  font-size: 10px;
}
