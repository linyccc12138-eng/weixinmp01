.page {
  padding-bottom: calc(56px + env(safe-area-inset-bottom));
}

.search-bar {
  padding: 12px 24px;
  background: #FFFFFF;
}

.search-input {
  height: 40px;
  background: #F7F7F7;
  border-radius: 100px;
  padding: 0 16px;
  font-size: 14px;
  color: #1A1A1A;
}

.course-list {
  padding: 12px 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.course-card {
  display: flex;
  background: #FFFFFF;
  border: 1px solid #F0F0F0;
  border-radius: 16px;
  padding: 12px;
  gap: 12px;
  transition: transform 140ms ease;
}

.course-card:active {
  transform: scale(0.97);
}

.course-cover {
  width: 120px;
  height: 68px;
  border-radius: 12px;
  flex-shrink: 0;
  background: #F7F7F7;
  overflow: hidden;
}

.course-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-placeholder-text {
  font-size: 24px;
  color: #BBB;
  font-weight: 500;
}

.course-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.course-title {
  font-size: 16px;
  font-weight: 500;
  color: #1A1A1A;
  line-height: 1.4;
}

.course-desc {
  font-size: 12px;
  color: #888;
  margin-top: 4px;
}

.course-meta {
  display: flex;
  gap: 12px;
  margin-top: 8px;
}

.meta-item {
  font-size: 11px;
  color: #888;
}

.meta-item.locked {
  color: #BBB;
}

.course-progress {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
}

.course-progress .progress-bar {
  flex: 1;
  height: 3px;
}

.course-progress .progress-text {
  font-size: 11px;
  color: #BBB;
  flex-shrink: 0;
}

.spinner {
  width: 28px;
  height: 28px;
  border: 2.5px solid #EEEEEE;
  border-top-color: #1A1A1A;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.load-more {
  padding: 16px;
  text-align: center;
}

.load-more-text {
  font-size: 13px;
  color: #888;
}
