<view class="page">
  <view class="search-bar" wx:if="{{isLoggedIn}}">
    <input class="search-input" placeholder="搜索课程" value="{{keyword}}" bindinput="onSearchInput" bindconfirm="onSearch" confirm-type="search" />
  </view>

  <view class="course-list" wx:if="{{courses.length > 0}}">
    <view class="course-card" wx:for="{{courses}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}" data-allowed="{{item.has_permission}}">
      <image class="course-cover" src="{{item.thumbnail_url}}" mode="aspectFill" wx:if="{{item.thumbnail_url}}"></image>
      <view class="course-cover course-cover-placeholder" wx:else>
        <view class="cover-placeholder-text">课</view>
      </view>
      <view class="course-info">
        <view class="course-title ellipsis-2">{{item.title}}</view>
        <view class="course-desc ellipsis">{{item.description || '暂无简介'}}</view>
        <view class="course-meta">
          <view class="meta-item">{{item.chapter_count || item.chapters_count || 0}} 章节</view>
          <view class="meta-item" wx:if="{{item.has_permission}}">已开通</view>
          <view class="meta-item locked" wx:else>未开通</view>
        </view>
        <view class="course-progress" wx:if="{{item.has_permission && item.progress}}">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.progress.percentage || 0}}%; background: {{item.progressColor}}"></view>
          </view>
          <view class="progress-text">{{item.progress.percentage || 0}}%</view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:elif="{{!loading}}">
    <view class="empty-state-text">{{isLoggedIn ? '暂无课程' : '请先登录查看课程'}}</view>
    <button class="btn-primary btn-small" wx:if="{{!isLoggedIn}}" bindtap="goLogin">去登录</button>
  </view>

  <view class="loading-spinner" wx:if="{{loading}}">
    <view class="spinner"></view>
  </view>

  <view class="load-more" wx:if="{{hasMore && !loading}}">
    <view class="load-more-text" bindtap="loadMore">加载更多</view>
  </view>
</view>
