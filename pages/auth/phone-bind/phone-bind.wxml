<view class="bind-page">
  <view class="bind-header">
    <view class="bind-title">绑定手机号</view>
    <view class="bind-desc">绑定手机号后即可使用完整功能</view>
  </view>

  <view class="bind-form">
    <button class="btn-primary wx-phone-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber" loading="{{wxLoading}}" disabled="{{wxLoading}}">
      微信手机号快捷绑定
    </button>

    <view class="divider-text">
      <view class="divider-line"></view>
      <view class="divider-label">或手动输入</view>
      <view class="divider-line"></view>
    </view>

    <view class="form-group">
      <view class="form-label">手机号</view>
      <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="form-group">
      <view class="form-label">密码</view>
      <input class="input-field" password placeholder="请设置密码（至少8位）" value="{{password}}" bindinput="onPasswordInput" />
    </view>
    <view class="form-group">
      <view class="form-label">确认密码</view>
      <input class="input-field" password placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmInput" bindconfirm="onBind" />
    </view>
    <view class="form-error" wx:if="{{errorMsg}}">{{errorMsg}}</view>
    <button class="btn-primary" bindtap="onBind" loading="{{submitting}}" disabled="{{submitting}}">
      绑定并登录
    </button>
  </view>
</view>
