.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 80px 24px 32px;
  background: #FFFFFF;
}

.login-header {
  text-align: center;
  margin-bottom: 48px;
}

.login-title {
  font-size: 26px;
  font-weight: 500;
  color: #1A1A1A;
  line-height: 1.3;
}

.login-desc {
  font-size: 14px;
  color: #888;
  margin-top: 8px;
}

.login-form {
  width: 100%;
}

.form-group {
  margin-bottom: 16px;
}

.form-label {
  font-size: 14px;
  color: #1A1A1A;
  margin-bottom: 8px;
}

.form-error {
  font-size: 12px;
  color: #EF4444;
  margin-bottom: 12px;
  padding: 8px 12px;
  background: #FFF0F0;
  border-radius: 8px;
}

.login-btn {
  width: 100%;
  margin-top: 24px;
}

.wechat-btn {
  width: 100%;
  margin-top: 12px;
  border-color: #0D9488;
  color: #0D9488;
}

.login-footer {
  margin-top: auto;
  padding-top: 32px;
  text-align: center;
}

.footer-text {
  font-size: 12px;
  color: #BBB;
}

.footer-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  margin-top: 4px;
}

.footer-link {
  font-size: 12px;
  color: #888;
}
