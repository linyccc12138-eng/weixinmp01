<view class="login-page">
  <view class="login-header">
    <view class="login-title">欢迎进入神奇喵喵屋</view>
    <view class="login-desc">登录后可使用课程学习和商城购物功能</view>
  </view>

  <view class="login-form">
    <view class="form-group">
      <view class="form-label">手机号</view>
      <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
    </view>
    <view class="form-group">
      <view class="form-label">密码</view>
      <input class="input-field" password placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" bindconfirm="onLogin" />
    </view>
    <view class="form-error" wx:if="{{errorMsg}}">{{errorMsg}}</view>
    <button class="btn-primary login-btn" bindtap="onLogin" loading="{{submitting}}" disabled="{{submitting}}">
      {{submitting ? '登录中...' : '登录'}}
    </button>
    <button class="btn-ghost wechat-btn" bindtap="onWxLogin" loading="{{wxLoading}}" disabled="{{wxLoading}}">
      微信快捷登录
    </button>
  </view>

  <view class="login-footer">
    <view class="footer-text">登录即表示同意</view>
    <view class="footer-links">
      <text class="footer-link" bindtap="viewAgreement" data-type="service">《用户服务协议》</text>
      <text class="footer-text">和</text>
      <text class="footer-link" bindtap="viewAgreement" data-type="privacy">《隐私政策》</text>
    </view>
  </view>
</view>
