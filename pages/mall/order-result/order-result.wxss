.page { padding: 32px 24px; text-align: center; }
.result-section { margin-bottom: 32px; }
.result-icon { width: 64px; height: 64px; border-radius: 100px; display: flex; align-items: center; justify-content: center; font-size: 28px; margin: 0 auto 16px; }
.result-icon.success { background: #E8F5E9; color: #22C55E; }
.result-icon.fail { background: #FFF3E0; color: #F59E0B; }
.result-title { font-size: 22px; font-weight: 500; color: #1A1A1A; }
.result-desc { font-size: 14px; color: #888; margin-top: 8px; }
.order-info { background: #FFFFFF; border: 1px solid #F0F0F0; border-radius: 16px; padding: 16px; margin-bottom: 24px; text-align: left; }
.info-row { display: flex; justify-content: space-between; padding: 8px 0; }
.info-label { font-size: 14px; color: #888; }
.info-value { font-size: 14px; color: #1A1A1A; }
.info-value.price { font-weight: 500; font-variant-numeric: tabular-nums; }
.actions { display: flex; flex-direction: column; gap: 12px; }
