.page { padding-bottom: 32px; }
.search-bar { padding: 12px 24px; background: #FFFFFF; }
.search-input { height: 40px; background: #F7F7F7; border-radius: 100px; padding: 0 16px; font-size: 14px; color: #1A1A1A; }
.filter-bar { padding: 0 24px 12px; background: #FFFFFF; }
.filter-scroll { white-space: nowrap; }
.filter-item { display: inline-flex; padding: 6px 16px; margin-right: 8px; border-radius: 100px; background: #F7F7F7; font-size: 13px; color: #888; }
.filter-item.active { background: #1A1A1A; color: #FFFFFF; }
.product-grid { display: flex; flex-wrap: wrap; padding: 12px 24px; gap: 10px; }
.product-card { width: calc((100% - 10px) / 2); background: #FFFFFF; border: 1px solid #F0F0F0; border-radius: 16px; overflow: hidden; }
.product-thumb { width: 100%; aspect-ratio: 1; background: #F7F7F7; }
.product-info { padding: 10px 12px 12px; }
.product-name { font-size: 13px; font-weight: 500; color: #1A1A1A; line-height: 1.4; min-height: 36px; }
.product-price-row { display: flex; align-items: baseline; gap: 4px; margin-top: 6px; }
.product-price { font-size: 16px; font-weight: 500; color: #1A1A1A; font-variant-numeric: tabular-nums; }
.product-original { font-size: 11px; color: #BBB; text-decoration: line-through; font-variant-numeric: tabular-nums; }
.spinner { width: 28px; height: 28px; border: 2.5px solid #EEE; border-top-color: #1A1A1A; border-radius: 50%; animation: spin 0.7s linear infinite; margin: 16px auto; }
@keyframes spin { to { transform: rotate(360deg); } }
