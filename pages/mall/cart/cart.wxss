.page { padding-bottom: 80px; }
.cart-header { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; background: #FFFFFF; }
.header-title { font-size: 18px; font-weight: 500; color: #1A1A1A; }
.header-count { font-size: 12px; color: #888; }
.cart-list { padding: 0 24px; }
.cart-item { display: flex; align-items: flex-start; padding: 16px 0; border-bottom: 1px solid #F0F0F0; gap: 12px; }
.item-check { padding-top: 20px; }
.checkbox { width: 20px; height: 20px; border-radius: 100px; border: 1.5px solid #E5E5E5; }
.checkbox.checked { background: #1A1A1A; border-color: #1A1A1A; }
.item-thumb { width: 80px; height: 80px; border-radius: 12px; background: #F7F7F7; flex-shrink: 0; }
.item-info { flex: 1; min-width: 0; }
.item-name { font-size: 14px; font-weight: 500; color: #1A1A1A; line-height: 1.4; }
.item-spec { font-size: 12px; color: #888; margin-top: 4px; }
.item-status { font-size: 12px; color: #EF4444; margin-top: 4px; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 8px; }
.item-price { font-size: 16px; font-weight: 500; color: #1A1A1A; font-variant-numeric: tabular-nums; }
.qty-control { display: flex; align-items: center; gap: 8px; }
.qty-btn { width: 28px; height: 28px; border-radius: 100px; border: 1px solid #E5E5E5; display: flex; align-items: center; justify-content: center; font-size: 14px; color: #1A1A1A; }
.qty-value { font-size: 14px; color: #1A1A1A; min-width: 24px; text-align: center; }
.item-delete { padding: 4px 8px; color: #BBB; font-size: 18px; }
.cart-footer { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; padding: 8px 24px; background: #FFFFFF; border-top: 1px solid #F0F0F0; z-index: 100; }
.footer-check { display: flex; align-items: center; gap: 8px; }
.check-label { font-size: 13px; color: #888; }
.footer-summary { flex: 1; text-align: right; padding-right: 12px; }
.summary-total { font-size: 13px; color: #888; }
.summary-price { font-size: 18px; font-weight: 500; color: #1A1A1A; font-variant-numeric: tabular-nums; }
.checkout-btn { flex-shrink: 0; }
