.page { padding-bottom: 80px; }
.gallery-swiper { height: 375px; }
.gallery-image { width: 100%; height: 375px; }
.product-info-section { padding: 20px 24px; background: #FFFFFF; }
.product-name { font-size: 22px; font-weight: 500; color: #1A1A1A; line-height: 1.3; }
.product-subtitle { font-size: 14px; color: #888; margin-top: 8px; }
.product-summary { font-size: 14px; color: #888; margin-top: 8px; line-height: 1.6; }
.price-row { display: flex; align-items: baseline; gap: 8px; margin-top: 12px; }
.current-price { font-size: 24px; font-weight: 500; color: #1A1A1A; font-variant-numeric: tabular-nums; }
.original-price { font-size: 14px; color: #BBB; text-decoration: line-through; font-variant-numeric: tabular-nums; }
.member-badge { font-size: 11px; color: #0D9488; background: rgba(13,148,136,0.1); padding: 2px 8px; border-radius: 100px; }
.stock-info { font-size: 12px; color: #888; margin-top: 8px; }
.sku-section { display: flex; align-items: center; padding: 14px 24px; background: #FFFFFF; margin-top: 8px; border-top: 1px solid #F0F0F0; border-bottom: 1px solid #F0F0F0; }
.sku-label { font-size: 14px; color: #1A1A1A; }
.sku-value { flex: 1; text-align: right; font-size: 14px; color: #888; margin: 0 8px; }
.sku-arrow { color: #BBB; font-size: 18px; }
.detail-section { padding: 20px 24px; background: #FFFFFF; margin-top: 8px; }
.detail-title { font-size: 18px; font-weight: 500; color: #1A1A1A; margin-bottom: 16px; }
.detail-content { font-size: 14px; color: #1A1A1A; line-height: 1.8; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; padding: 8px 24px; background: rgba(255,255,255,0.95); border-top: 1px solid #F0F0F0; z-index: 100; }
.bar-icon { position: relative; padding: 8px 16px; }
.icon-text { font-size: 22px; }
.cart-badge { position: absolute; top: 0; right: 4px; min-width: 16px; height: 16px; background: #EF4444; color: #FFF; font-size: 10px; border-radius: 100px; display: flex; align-items: center; justify-content: center; padding: 0 4px; }
.bar-actions { flex: 1; display: flex; gap: 8px; justify-content: flex-end; }
.sku-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 200; }
.sku-panel { position: fixed; left: 0; right: 0; bottom: 0; background: #FFFFFF; border-radius: 24px 24px 0 0; z-index: 201; transform: translateY(100%); transition: transform 400ms cubic-bezier(0.34,1.56,0.64,1); max-height: 70vh; display: flex; flex-direction: column; }
.sku-panel.show { transform: translateY(0); }
.sku-panel-header { display: flex; padding: 20px 24px; gap: 12px; border-bottom: 1px solid #F0F0F0; }
.sku-thumb { width: 80px; height: 80px; border-radius: 12px; background: #F7F7F7; }
.sku-panel-info { flex: 1; }
.sku-panel-price { font-size: 20px; font-weight: 500; color: #1A1A1A; font-variant-numeric: tabular-nums; }
.sku-panel-stock { font-size: 12px; color: #888; margin-top: 4px; }
.sku-panel-selected { font-size: 12px; color: #888; margin-top: 4px; }
.sku-close { font-size: 24px; color: #BBB; padding: 4px; }
.sku-panel-body { flex: 1; padding: 16px 24px; overflow-y: auto; }
.sku-group { margin-bottom: 20px; }
.sku-group-name { font-size: 14px; font-weight: 500; color: #1A1A1A; margin-bottom: 10px; }
.sku-options { display: flex; flex-wrap: wrap; gap: 8px; }
.sku-option { padding: 6px 16px; border-radius: 100px; border: 1px solid #E5E5E5; font-size: 13px; color: #1A1A1A; }
.sku-option.active { background: #1A1A1A; color: #FFFFFF; border-color: #1A1A1A; }
.quantity-section { display: flex; align-items: center; justify-content: space-between; padding: 12px 0; }
.quantity-label { font-size: 14px; color: #1A1A1A; }
.quantity-control { display: flex; align-items: center; gap: 8px; }
.qty-btn { width: 32px; height: 32px; border-radius: 100px; border: 1px solid #E5E5E5; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #1A1A1A; }
.qty-input { width: 48px; height: 32px; text-align: center; font-size: 14px; color: #1A1A1A; }
.sku-panel-footer { padding: 12px 24px; border-top: 1px solid #F0F0F0; }
