<view class="page">
  <view class="status-section">
    <view class="status-label">{{order.statusLabel}}</view>
  </view>

  <view class="address-section" wx:if="{{order.address_snapshot}}">
    <view class="address-name">{{order.address_snapshot.receiver_name}} {{order.address_snapshot.receiver_phone}}</view>
    <view class="address-detail">{{addressText}}</view>
  </view>

  <view class="shipping-section" wx:if="{{order.shipping_company || order.shipping_no}}">
    <view class="shipping-title">物流信息</view>
    <view class="shipping-row" wx:if="{{order.shipping_company}}">
      <view class="shipping-label">物流公司</view>
      <view class="shipping-value">{{order.shipping_company}}</view>
    </view>
    <view class="shipping-row" wx:if="{{order.shipping_no}}">
      <view class="shipping-label">物流单号</view>
      <view class="shipping-value">{{order.shipping_no}}</view>
      <view class="copy-btn" bindtap="copyShippingNo">复制</view>
    </view>
  </view>

  <view class="items-section">
    <view class="section-title">商品清单</view>
    <view class="item-row" wx:for="{{order.items}}" wx:key="id">
      <image class="item-thumb" src="{{item.cover_image}}" mode="aspectFill"></image>
      <view class="item-info">
        <view class="item-name ellipsis">{{item.product_name}}</view>
        <view class="item-spec" wx:if="{{item.sku_name}}">{{item.sku_name}}</view>
        <view class="item-bottom">
          <view class="item-price">¥{{item.line_total}}</view>
          <view class="item-qty">×{{item.quantity}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="info-section">
    <view class="info-row">
      <view class="info-label">订单号</view>
      <view class="info-value">{{order.order_no}}</view>
      <view class="copy-btn" bindtap="copyOrderNo">复制</view>
    </view>
    <view class="info-row">
      <view class="info-label">下单时间</view>
      <view class="info-value">{{order.placed_at}}</view>
    </view>
    <view class="info-row">
      <view class="info-label">支付方式</view>
      <view class="info-value">{{paymentLabel}}</view>
    </view>
    <view class="info-row total">
      <view class="info-label">应付金额</view>
      <view class="info-value price">¥{{order.payable_amount}}</view>
    </view>
  </view>

  <view class="close-section" wx:if="{{order.status === 'closed'}}">
    <view class="close-info">关闭原因：{{closedReason}}</view>
    <view class="close-time" wx:if="{{order.closed_at}}">关闭时间：{{order.closed_at}}</view>
  </view>

  <view class="bottom-bar safe-bottom" wx:if="{{order.status === 'pending_payment' || order.status === 'pending_receipt'}}">
    <button class="btn-ghost btn-small" wx:if="{{order.status === 'pending_payment'}}" bindtap="cancelOrder">取消订单</button>
    <button class="btn-primary btn-small" wx:if="{{order.status === 'pending_payment'}}" bindtap="payOrder">立即付款</button>
    <button class="btn-primary btn-small" wx:if="{{order.status === 'pending_receipt'}}" bindtap="completeOrder">确认收货</button>
  </view>
</view>
