.page { padding-bottom: 32px; }
.activity-cover { width: 100%; }
.cover-image { width: 100%; height: 200px; }
.activity-info { padding: 20px 24px; background: #FFFFFF; }
.activity-title { font-size: 22px; font-weight: 500; color: #1A1A1A; line-height: 1.3; }
.activity-summary { font-size: 14px; color: #888; margin-top: 8px; line-height: 1.6; }
.activity-time { font-size: 12px; color: #BBB; margin-top: 8px; }
.activity-content { padding: 20px 24px; background: #FFFFFF; margin-top: 8px; font-size: 14px; color: #1A1A1A; line-height: 1.8; }
