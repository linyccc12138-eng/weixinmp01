<view class="page">
  <view class="search-bar" bindtap="goSearch">
    <view class="search-input-placeholder">搜索商品</view>
  </view>

  <swiper class="banner-swiper" indicator-dots indicator-color="rgba(26,26,26,0.3)" indicator-active-color="#1A1A1A" autoplay circular wx:if="{{banners.length > 0}}">
    <swiper-item wx:for="{{banners}}" wx:key="id" bindtap="onBannerTap" data-item="{{item}}">
      <image class="banner-image" src="{{item.image || item.thumbnail_image}}" mode="aspectFill"></image>
    </swiper-item>
  </swiper>

  <view class="category-nav" wx:if="{{categories.length > 0}}">
    <scroll-view scroll-x class="category-scroll">
      <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="goCategory" data-id="{{item.id}}">
        <view class="category-name">{{item.name}}</view>
      </view>
    </scroll-view>
  </view>

  <view class="member-card" wx:if="{{memberInfo}}" bindtap="goWallet">
    <view class="member-info">
      <view class="member-level">{{memberInfo.fclassesname || '会员'}}</view>
      <view class="member-discount" wx:if="{{hasMemberDiscount}}">享{{memberDiscountLabel}}折优惠</view>
    </view>
    <view class="member-balance">余额 ¥{{memberBalance}}</view>
  </view>

  <view class="section" wx:if="{{newProducts.length > 0}}">
    <view class="section-header">
      <view class="section-title">新品上架</view>
    </view>
    <scroll-view scroll-x class="product-scroll">
      <view class="product-item" wx:for="{{newProducts}}" wx:key="id" bindtap="goProduct" data-id="{{item.id}}">
        <image class="product-thumb" src="{{item.cover_image}}" mode="aspectFill"></image>
        <view class="product-name ellipsis">{{item.name}}</view>
        <view class="product-price-row">
          <view class="product-price">¥{{item.price}}</view>
          <view class="product-original-price" wx:if="{{item.hasOriginalPrice}}">¥{{item.original_price}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="section-header">
      <view class="section-title">精选商品</view>
    </view>
    <view class="product-grid">
      <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goProduct" data-id="{{item.id}}">
        <image class="product-card-thumb" src="{{item.cover_image}}" mode="aspectFill"></image>
        <view class="product-card-info">
          <view class="product-card-name ellipsis-2">{{item.name}}</view>
          <view class="product-card-price-row">
            <view class="product-card-price">¥{{item.price}}</view>
            <view class="product-card-original" wx:if="{{item.hasOriginalPrice}}">¥{{item.original_price}}</view>
          </view>
          <view class="product-card-member" wx:if="{{item.showMemberPrice}}">
            会员¥{{item.memberPrice}}
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="load-more" wx:if="{{loading}}">
    <view class="spinner"></view>
  </view>
</view>
