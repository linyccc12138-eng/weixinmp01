.page {
  padding-bottom: calc(56px + env(safe-area-inset-bottom));
}

.search-bar {
  padding: 12px 24px;
  background: #FFFFFF;
}

.search-input-placeholder {
  height: 40px;
  background: #F7F7F7;
  border-radius: 100px;
  display: flex;
  align-items: center;
  padding: 0 16px;
  font-size: 14px;
  color: #BBB;
}

.banner-swiper {
  height: 180px;
  margin: 0 24px;
  border-radius: 12px;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.category-nav {
  padding: 12px 0;
}

.category-scroll {
  white-space: nowrap;
  padding: 0 24px;
}

.category-item {
  display: inline-flex;
  padding: 6px 16px;
  margin-right: 8px;
  background: #F7F7F7;
  border-radius: 100px;
}

.category-name {
  font-size: 13px;
  color: #1A1A1A;
}

.member-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24px 12px;
  padding: 16px;
  background: #FFFFFF;
  border: 1px solid #F0F0F0;
  border-radius: 16px;
}

.member-level {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A1A;
}

.member-discount {
  font-size: 12px;
  color: #0D9488;
  margin-top: 2px;
}

.member-balance {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A1A;
  font-variant-numeric: tabular-nums;
}

.section {
  margin-top: 12px;
}

.section-header {
  padding: 12px 24px 8px;
}

.section-title {
  font-size: 18px;
  font-weight: 500;
  color: #1A1A1A;
}

.product-scroll {
  white-space: nowrap;
  padding: 0 24px;
}

.product-item {
  display: inline-flex;
  flex-direction: column;
  width: 140px;
  margin-right: 10px;
  vertical-align: top;
}

.product-thumb {
  width: 140px;
  height: 140px;
  border-radius: 12px;
  background: #F7F7F7;
}

.product-name {
  font-size: 13px;
  font-weight: 500;
  color: #1A1A1A;
  margin-top: 8px;
}

.product-price-row {
  display: flex;
  align-items: baseline;
  gap: 6px;
  margin-top: 4px;
}

.product-price {
  font-size: 16px;
  font-weight: 500;
  color: #1A1A1A;
  font-variant-numeric: tabular-nums;
}

.product-original-price {
  font-size: 12px;
  color: #BBB;
  text-decoration: line-through;
  font-variant-numeric: tabular-nums;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24px;
  gap: 10px;
}

.product-card {
  width: calc((100% - 10px) / 2);
  background: #FFFFFF;
  border: 1px solid #F0F0F0;
  border-radius: 16px;
  overflow: hidden;
}

.product-card-thumb {
  width: 100%;
  aspect-ratio: 1;
  background: #F7F7F7;
}

.product-card-info {
  padding: 10px 12px 12px;
}

.product-card-name {
  font-size: 13px;
  font-weight: 500;
  color: #1A1A1A;
  line-height: 1.4;
  min-height: 36px;
}

.product-card-price-row {
  display: flex;
  align-items: baseline;
  gap: 4px;
  margin-top: 6px;
}

.product-card-price {
  font-size: 16px;
  font-weight: 500;
  color: #1A1A1A;
  font-variant-numeric: tabular-nums;
}

.product-card-original {
  font-size: 11px;
  color: #BBB;
  text-decoration: line-through;
  font-variant-numeric: tabular-nums;
}

.product-card-member {
  font-size: 11px;
  color: #0D9488;
  margin-top: 2px;
  font-variant-numeric: tabular-nums;
}

.spinner {
  width: 28px;
  height: 28px;
  border: 2.5px solid #EEEEEE;
  border-top-color: #1A1A1A;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  margin: 16px auto;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
