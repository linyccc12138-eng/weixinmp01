.page { padding-bottom: 80px; }
.address-section { display: flex; align-items: center; padding: 16px 24px; background: #FFFFFF; border-bottom: 1px solid #F0F0F0; }
.address-card { flex: 1; }
.address-name { font-size: 16px; font-weight: 500; color: #1A1A1A; }
.address-detail { font-size: 13px; color: #888; margin-top: 4px; line-height: 1.5; }
.address-empty { flex: 1; }
.empty-text { font-size: 14px; color: #888; }
.address-arrow { color: #BBB; font-size: 18px; padding-left: 8px; }
.items-section { padding: 16px 24px; background: #FFFFFF; margin-top: 8px; }
.item-row { display: flex; gap: 12px; padding: 8px 0; border-bottom: 1px solid #F7F7F7; }
.item-thumb { width: 60px; height: 60px; border-radius: 12px; background: #F7F7F7; flex-shrink: 0; }
.item-info { flex: 1; min-width: 0; }
.item-name { font-size: 14px; color: #1A1A1A; }
.item-spec { font-size: 12px; color: #888; margin-top: 2px; }
.item-price-row { display: flex; justify-content: space-between; margin-top: 4px; }
.item-price { font-size: 14px; font-weight: 500; color: #1A1A1A; font-variant-numeric: tabular-nums; }
.item-qty { font-size: 12px; color: #888; }
.summary-section { padding: 16px 24px; background: #FFFFFF; margin-top: 8px; }
.summary-row { display: flex; justify-content: space-between; padding: 6px 0; font-size: 14px; color: #888; }
.summary-row.total { padding-top: 12px; border-top: 1px solid #F0F0F0; margin-top: 6px; }
.summary-row.total .summary-label { color: #1A1A1A; font-weight: 500; }
.summary-value { font-variant-numeric: tabular-nums; }
.summary-value.discount { color: #22C55E; }
.summary-value.price { font-size: 18px; font-weight: 500; color: #1A1A1A; }
.payment-section { padding: 16px 24px; background: #FFFFFF; margin-top: 8px; }
.payment-title { font-size: 14px; font-weight: 500; color: #1A1A1A; margin-bottom: 12px; }
.payment-option { display: flex; align-items: center; padding: 12px 0; gap: 10px; border-bottom: 1px solid #F7F7F7; }
.payment-radio { width: 18px; height: 18px; border-radius: 100px; border: 1.5px solid #E5E5E5; }
.payment-option.active .payment-radio { background: #1A1A1A; border-color: #1A1A1A; }
.payment-name { font-size: 14px; color: #1A1A1A; }
.payment-balance { font-size: 12px; color: #888; margin-left: auto; font-variant-numeric: tabular-nums; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; align-items: center; justify-content: space-between; padding: 8px 24px; background: #FFFFFF; border-top: 1px solid #F0F0F0; z-index: 100; }
.bottom-total { font-size: 14px; color: #888; }
.bottom-price { font-size: 18px; font-weight: 500; color: #1A1A1A; font-variant-numeric: tabular-nums; }
