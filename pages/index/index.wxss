.page {
  padding-bottom: calc(56px + env(safe-area-inset-bottom));
}

.header {
  padding: 32px 24px 24px;
}

.header-title {
  font-size: 26px;
  font-weight: 500;
  color: #1A1A1A;
  line-height: 1.3;
}

.header-subtitle {
  font-size: 14px;
  color: #888;
  margin-top: 8px;
}

.entry-cards {
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.entry-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border: 1px solid #F0F0F0;
  border-radius: 16px;
  padding: 20px 16px;
  gap: 16px;
  transition: transform 140ms ease;
}

.entry-card:active {
  transform: scale(0.97);
}

.entry-icon {
  width: 56px;
  height: 56px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
  font-weight: 500;
  flex-shrink: 0;
}

.course-icon {
  background: rgba(13, 148, 136, 0.1);
  color: #0D9488;
}

.mall-icon {
  background: rgba(26, 26, 26, 0.06);
  color: #1A1A1A;
}

.entry-info {
  flex: 1;
  min-width: 0;
}

.entry-title {
  font-size: 18px;
  font-weight: 500;
  color: #1A1A1A;
}

.entry-desc {
  font-size: 12px;
  color: #888;
  margin-top: 4px;
}

.entry-arrow {
  font-size: 20px;
  color: #BBB;
  flex-shrink: 0;
}

.section {
  margin-top: 24px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  margin-bottom: 12px;
}

.section-title {
  font-size: 18px;
  font-weight: 500;
  color: #1A1A1A;
}

.section-more {
  font-size: 12px;
  color: #888;
}

.activity-scroll {
  white-space: nowrap;
  padding: 0 24px;
}

.activity-item {
  display: inline-flex;
  align-items: center;
  width: 280px;
  background: #FFFFFF;
  border: 1px solid #F0F0F0;
  border-radius: 16px;
  padding: 12px;
  gap: 12px;
  margin-right: 12px;
  vertical-align: top;
}

.activity-thumb {
  width: 80px;
  height: 80px;
  border-radius: 12px;
  flex-shrink: 0;
  background: #F7F7F7;
}

.activity-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #BBB;
  font-size: 12px;
}

.activity-info {
  flex: 1;
  min-width: 0;
}

.activity-title {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A1A;
}

.activity-summary {
  font-size: 12px;
  color: #888;
  margin-top: 4px;
  line-height: 1.5;
}

.product-scroll {
  white-space: nowrap;
  padding: 0 24px;
}

.product-item {
  display: inline-flex;
  flex-direction: column;
  width: 140px;
  margin-right: 10px;
  vertical-align: top;
}

.product-thumb {
  width: 140px;
  height: 140px;
  border-radius: 12px;
  background: #F7F7F7;
}

.product-name {
  font-size: 13px;
  font-weight: 500;
  color: #1A1A1A;
  margin-top: 8px;
}

.product-price {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A1A;
  margin-top: 4px;
  font-variant-numeric: tabular-nums;
}

.course-list {
  padding: 0 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.course-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border: 1px solid #F0F0F0;
  border-radius: 16px;
  padding: 12px;
  gap: 12px;
}

.course-thumb {
  width: 96px;
  height: 54px;
  border-radius: 12px;
  flex-shrink: 0;
  background: #F7F7F7;
  overflow: hidden;
}

.course-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.course-placeholder-text {
  font-size: 20px;
  color: #BBB;
  font-weight: 500;
}

.course-info {
  flex: 1;
  min-width: 0;
}

.course-name {
  font-size: 14px;
  font-weight: 500;
  color: #1A1A1A;
}

.course-summary {
  font-size: 12px;
  color: #888;
  margin-top: 4px;
}
