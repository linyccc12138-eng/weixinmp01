<view class="page">
  <view class="history-list" wx:if="{{records.length > 0}}">
    <view class="history-item" wx:for="{{records}}" wx:key="id" bindtap="goPlay" data-chapter-id="{{item.chapter_id}}" data-course-id="{{item.course_id}}">
      <view class="history-info">
        <view class="history-title ellipsis">{{item.chapter_title || item.course_title}}</view>
        <view class="history-course" wx:if="{{item.course_title}}">{{item.course_title}}</view>
        <view class="history-meta">
          <view class="meta-time">{{item.played_at}}</view>
          <view class="meta-progress" wx:if="{{item.progress}}">{{item.progress.percentage}}%</view>
        </view>
      </view>
      <view class="history-progress">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.progress ? item.progress.percentage : 0}}%"></view>
        </view>
      </view>
    </view>
  </view>
  <view class="empty-state" wx:elif="{{!loading}}">
    <view class="empty-state-text">暂无播放记录</view>
  </view>
  <view class="loading-spinner" wx:if="{{loading}}">
    <view class="spinner"></view>
  </view>
</view>
