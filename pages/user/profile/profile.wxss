.page { padding-bottom: calc(56px + env(safe-area-inset-bottom)); }
.profile-header { display: flex; align-items: center; padding: 24px; background: #FFFFFF; gap: 16px; }
.avatar { width: 48px; height: 48px; border-radius: 100px; background: #F7F7F7; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 500; color: #888; flex-shrink: 0; }
.user-info { flex: 1; }
.user-name { font-size: 18px; font-weight: 500; color: #1A1A1A; }
.user-phone { font-size: 13px; color: #888; margin-top: 2px; }
.login-btn { padding: 6px 20px; background: #1A1A1A; color: #FFFFFF; border-radius: 100px; font-size: 14px; font-weight: 500; }
.member-card { display: flex; align-items: center; justify-content: space-between; margin: 12px 24px; padding: 16px; background: #FFFFFF; border: 1px solid #F0F0F0; border-radius: 16px; }
.member-level { font-size: 14px; font-weight: 500; color: #1A1A1A; }
.member-discount { font-size: 12px; color: #0D9488; margin-top: 2px; }
.member-balance { font-size: 14px; font-weight: 500; color: #1A1A1A; font-variant-numeric: tabular-nums; }
.stats-card { display: flex; margin: 12px 24px; padding: 16px; background: #FFFFFF; border: 1px solid #F0F0F0; border-radius: 16px; }
.stat-item { flex: 1; text-align: center; }
.stat-value { font-size: 24px; font-weight: 500; color: #1A1A1A; }
.stat-label { font-size: 12px; color: #888; margin-top: 4px; }
.menu-list { margin-top: 12px; background: #FFFFFF; }
.menu-item { display: flex; align-items: center; justify-content: space-between; padding: 16px 24px; border-bottom: 1px solid #F7F7F7; }
.menu-text { font-size: 15px; color: #1A1A1A; }
.menu-arrow { color: #BBB; font-size: 16px; }
.menu-item.logout { justify-content: center; }
.menu-item.logout .menu-text { color: #EF4444; }
