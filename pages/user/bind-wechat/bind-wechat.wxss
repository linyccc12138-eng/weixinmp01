.page { padding: 32px 24px; }
.bind-status { text-align: center; margin-bottom: 32px; }
.status-icon { width: 64px; height: 64px; border-radius: 100px; display: flex; align-items: center; justify-content: center; font-size: 28px; margin: 0 auto 16px; }
.status-icon.bound { background: #E8F5E9; color: #22C55E; }
.status-icon.unbound { background: #FFF3E0; color: #F59E0B; }
.status-text { font-size: 18px; font-weight: 500; color: #1A1A1A; }
.status-desc { font-size: 13px; color: #888; margin-top: 8px; }
.bind-actions { }
