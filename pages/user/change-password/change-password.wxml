<view class="page">
  <view class="form">
    <view class="form-group">
      <view class="form-label">当前密码</view>
      <input class="input-field" password placeholder="请输入当前密码" value="{{currentPassword}}" bindinput="onInput" data-field="currentPassword" />
    </view>
    <view class="form-group">
      <view class="form-label">新密码</view>
      <input class="input-field" password placeholder="请输入新密码（至少8位）" value="{{newPassword}}" bindinput="onInput" data-field="newPassword" />
    </view>
    <view class="form-group">
      <view class="form-label">确认新密码</view>
      <input class="input-field" password placeholder="请再次输入新密码" value="{{confirmPassword}}" bindinput="onInput" data-field="confirmPassword" />
    </view>
    <view class="form-error" wx:if="{{errorMsg}}">{{errorMsg}}</view>
    <button class="btn-primary" bindtap="changePassword" loading="{{submitting}}" disabled="{{submitting}}">确认修改</button>
  </view>
</view>
