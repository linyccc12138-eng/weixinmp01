<view class="page">
  <view class="address-list" wx:if="{{addresses.length > 0}}">
    <view class="address-card" wx:for="{{addresses}}" wx:key="id">
      <view class="address-info" bindtap="selectAddress" data-id="{{item.id}}">
        <view class="address-name">{{item.receiver_name}} {{item.receiver_phone}}</view>
        <view class="address-detail">{{item.province}}{{item.city}}{{item.district}}{{item.detail_address}}</view>
        <view class="address-default" wx:if="{{item.is_default}}">默认</view>
      </view>
      <view class="address-actions">
        <view class="action-btn" bindtap="editAddress" data-id="{{item.id}}">编辑</view>
        <view class="action-btn" bindtap="setDefault" data-id="{{item.id}}" wx:if="{{!item.is_default}}">设为默认</view>
        <view class="action-btn delete" bindtap="deleteAddress" data-id="{{item.id}}">删除</view>
      </view>
    </view>
  </view>
  <view class="empty-state" wx:else>
    <view class="empty-state-text">暂无收货地址</view>
  </view>
  <view class="bottom-bar safe-bottom">
    <button class="btn-primary" bindtap="addAddress">新增收货地址</button>
  </view>
</view>
