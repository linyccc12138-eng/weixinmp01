<view class="page">
  <view class="form">
    <view class="form-group">
      <view class="form-label">收货人</view>
      <input class="input-field" placeholder="请输入收货人姓名" value="{{form.receiver_name}}" bindinput="onInput" data-field="receiver_name" />
    </view>
    <view class="form-group">
      <view class="form-label">手机号</view>
      <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.receiver_phone}}" bindinput="onInput" data-field="receiver_phone" />
    </view>
    <view class="form-group">
      <view class="form-label">所在地区</view>
      <picker mode="region" value="{{region}}" bindchange="onRegionChange">
        <view class="region-picker {{regionText ? '' : 'placeholder'}}">
          {{regionText || '请选择省/市/区'}}
        </view>
      </picker>
    </view>
    <view class="form-group">
      <view class="form-label">详细地址</view>
      <textarea class="input-field textarea" placeholder="请输入详细地址" value="{{form.detail_address}}" bindinput="onInput" data-field="detail_address" />
    </view>
    <view class="form-group switch-group">
      <view class="form-label">设为默认地址</view>
      <switch checked="{{form.is_default}}" bindchange="onSwitchChange" color="#1A1A1A" />
    </view>
    <view class="form-error" wx:if="{{errorMsg}}">{{errorMsg}}</view>
    <button class="btn-primary" bindtap="save" loading="{{submitting}}" disabled="{{submitting}}">保存</button>
  </view>
</view>
