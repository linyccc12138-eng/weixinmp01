page {
  --color-primary: #1A1A1A;
  --color-secondary: #888888;
  --color-placeholder: #BBBBBB;
  --color-border: #E5E5E5;
  --color-bg: #F7F7F7;
  --color-card: #FFFFFF;
  --color-success: #22C55E;
  --color-warning: #F59E0B;
  --color-error: #EF4444;
  --color-info: #3B82F6;
  --color-teal: #0D9488;

  --font-display: 26px;
  --font-h1: 22px;
  --font-h2: 18px;
  --font-h3: 16px;
  --font-body: 14px;
  --font-caption: 12px;
  --font-label: 11px;
  --font-price: 18px;

  --space-1: 4px;
  --space-2: 8px;
  --space-3: 12px;
  --space-4: 16px;
  --space-5: 20px;
  --space-6: 24px;
  --space-8: 32px;

  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 24px;
  --radius-full: 100px;

  --safe-bottom: env(safe-area-inset-bottom);

  background-color: var(--color-bg);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
  color: var(--color-primary);
  font-size: var(--font-body);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

.container {
  padding: 0 var(--space-6);
}

.card {
  background: var(--color-card);
  border-radius: var(--radius-lg);
  padding: var(--space-4);
  border: 1px solid #F0F0F0;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 15px;
  font-weight: 500;
  border-radius: var(--radius-full);
  padding: 0 24px;
  border: none;
  transition: opacity 200ms ease;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary[disabled] {
  background: #EEEEEE;
  color: #CCCCCC;
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  background: transparent;
  color: var(--color-primary);
  font-size: 15px;
  font-weight: 500;
  border-radius: var(--radius-full);
  padding: 0 24px;
  border: 1px solid var(--color-border);
  transition: opacity 200ms ease;
}

.btn-ghost:active {
  opacity: 0.7;
}

.btn-danger {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 48px;
  background: #FFF0F0;
  color: #C0392B;
  font-size: 15px;
  font-weight: 500;
  border-radius: var(--radius-full);
  padding: 0 24px;
  border: 1px solid #FFCCCC;
}

.btn-small {
  height: 36px;
  font-size: 13px;
  padding: 0 16px;
}

.input-field {
  height: 48px;
  background: var(--color-bg);
  border: 1px solid transparent;
  border-radius: var(--radius-md);
  padding: 0 16px;
  font-size: var(--font-body);
  color: var(--color-primary);
  transition: border-color 200ms ease;
}

.input-field:focus {
  border-color: var(--color-primary);
}

.section-title {
  font-size: var(--font-h2);
  font-weight: 500;
  color: var(--color-primary);
  margin-bottom: var(--space-4);
}

.text-primary {
  color: var(--color-primary);
}

.text-secondary {
  color: var(--color-secondary);
}

.text-placeholder {
  color: var(--color-placeholder);
}

.text-success {
  color: var(--color-success);
}

.text-warning {
  color: var(--color-warning);
}

.text-error {
  color: var(--color-error);
}

.text-teal {
  color: var(--color-teal);
}

.price {
  font-size: var(--font-price);
  font-weight: 500;
  font-variant-numeric: tabular-nums;
  color: var(--color-primary);
}

.price-original {
  font-size: var(--font-caption);
  color: var(--color-placeholder);
  text-decoration: line-through;
  font-variant-numeric: tabular-nums;
}

.divider {
  height: 1px;
  background: var(--color-border);
  margin: var(--space-4) 0;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 22px;
  padding: 0 10px;
  background: #F5F5F5;
  color: var(--color-secondary);
  font-size: var(--font-label);
  border-radius: var(--radius-full);
}

.progress-bar {
  height: 6px;
  background: #F0F0F0;
  border-radius: var(--radius-full);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--color-primary);
  border-radius: var(--radius-full);
  transition: width 600ms cubic-bezier(0.34, 1.2, 0.64, 1);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80px 32px;
}

.empty-state-icon {
  width: 64px;
  height: 64px;
  margin-bottom: var(--space-4);
  opacity: 0.3;
}

.empty-state-text {
  font-size: var(--font-body);
  color: var(--color-secondary);
  margin-bottom: var(--space-5);
}

.loading-spinner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32px;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

.animate-in {
  animation: fadeIn 350ms cubic-bezier(0.34, 1.2, 0.64, 1) both;
}

.safe-bottom {
  padding-bottom: calc(56px + var(--safe-bottom));
}
